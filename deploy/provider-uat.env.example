# Copy to a private .env file on the server. Do not commit real secrets.

HOST_PHOTOVIEW_LOCATION=/opt/photoview
HOST_PHOTOVIEW_MEDIA_ROOT=/srv/photos
HOST_PHOTOVIEW_BACKUP=/srv/backups/photoview

PHOTOVIEW_DATABASE_DRIVER=mysql
MARIADB_DATABASE=photoview
MARIADB_USER=photoview
MARIADB_PASSWORD=change_me
MARIADB_ROOT_PASSWORD=change_root_me

PHOTOVIEW_PROVIDER_AUTH_ENABLED=1
PHOTOVIEW_PROVIDER_AUTO_PROVISION=1
PHOTOVIEW_PROVIDER_HEALTH_ID_BASE_URL=https://moph.id.th
PHOTOVIEW_PROVIDER_HEALTH_ID_CLIENT_ID=fill_from_secret_store
PHOTOVIEW_PROVIDER_HEALTH_ID_CLIENT_SECRET=fill_from_secret_store
PHOTOVIEW_PROVIDER_HEALTH_ID_REDIRECT_URI=https://photos-uat.example.com/api/auth/provider/callback
PHOTOVIEW_PROVIDER_HEALTH_ID_SCOPE=openid profile
PHOTOVIEW_PROVIDER_BASE_URL=https://provider.id.th
PHOTOVIEW_PROVIDER_CLIENT_ID=fill_from_secret_store
PHOTOVIEW_PROVIDER_SECRET_KEY=fill_from_secret_store
PHOTOVIEW_INITIAL_ROOT_PATH=/photos

WATCHTOWER_POLL_INTERVAL=86400
WATCHTOWER_TIMEOUT=30s
WATCHTOWER_CLEANUP=true
